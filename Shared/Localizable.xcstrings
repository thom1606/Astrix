    "Actions run top to bottom when you launch this workspace. Commands stay tracked, you may stop them from the workspace's menu bar submenu at any time." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las acciones se ejecutan de arriba abajo cuando inicias este espacio de trabajo. Los comandos se mantienen en seguimiento y puedes detenerlos en cualquier momento desde el submenú de la barra de menús del espacio de trabajo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acties worden van boven naar beneden uitgevoerd wanneer je deze werkruimte start. Opdrachten blijven gevolgd; je kunt ze op elk moment stoppen via het submenu in de menubalk van de werkruimte."
          }
        }
      }
    },
